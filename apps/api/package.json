{
  "name": "@hookshield/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsup src/server.ts --format esm --platform node --target node22 --out-dir dist --sourcemap",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cookie": "11.1.1",
    "@fastify/cors": "11.3.0",
    "@fastify/helmet": "13.1.0",
    "@fastify/rate-limit": "11.1.0",
    "@hookshield/contracts": "workspace:*",
    "@hookshield/database": "workspace:*",
    "@hookshield/security": "workspace:*",
    "fastify": "5.10.0",
    "fastify-raw-body": "5.0.0",
    "stripe": "22.3.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "tsup": "8.5.1",
    "tsx": "4.23.1",
    "typescript": "5.9.3"
  }
}
